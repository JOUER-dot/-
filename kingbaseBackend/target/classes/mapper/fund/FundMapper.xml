<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.roboadvisor.fund.mapper.FundMapper">

    <resultMap id="FundOptionResultMap" type="com.finance.roboadvisor.fund.vo.FundOptionVO">
        <id property="id" column="id"/>
        <result property="fundCode" column="fund_code"/>
        <result property="fundName" column="fund_name"/>
        <result property="fundType" column="fund_type"/>
        <result property="riskLevel" column="risk_level"/>
        <result property="companyName" column="company_name"/>
        <result property="status" column="status"/>
    </resultMap>

    <sql id="FundFilterWhere">
        from app.fund_info
        where status = 1
        <if test="keyword != null and keyword != ''">
            and (
                fund_code like concat('%', #{keyword}, '%')
                or fund_name like concat('%', #{keyword}, '%')
            )
        </if>
        <if test="fundType != null and fundType != ''">
            and fund_type = #{fundType}
        </if>
    </sql>

    <select id="selectEnabledFunds" resultMap="FundOptionResultMap">
        select id, fund_code, fund_name, fund_type, risk_level, company_name, status
        <include refid="FundFilterWhere"/>
        order by updated_at desc, id desc
        limit #{pageSize} offset #{offset}
    </select>

    <select id="countEnabledFunds" resultType="long">
        select count(1)
        <include refid="FundFilterWhere"/>
    </select>

    <select id="selectEnabledFundsByIds" resultMap="FundOptionResultMap">
        select id, fund_code, fund_name, fund_type, risk_level, company_name, status
        from app.fund_info
        where status = 1
          and id in
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>
