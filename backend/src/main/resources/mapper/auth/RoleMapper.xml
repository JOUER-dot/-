<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.roboadvisor.auth.mapper.RoleMapper">

    <resultMap id="SysRoleResultMap" type="com.finance.roboadvisor.auth.entity.SysRole">
        <id property="id" column="id"/>
        <result property="roleCode" column="role_code"/>
        <result property="roleName" column="role_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectByRoleCode" resultMap="SysRoleResultMap">
        select id, role_code, role_name, status, created_at, updated_at
        from sys_role
        where role_code = #{roleCode}
        limit 1
    </select>

    <select id="selectRolesByUserId" resultMap="SysRoleResultMap">
        select r.id, r.role_code, r.role_name, r.status, r.created_at, r.updated_at
        from sys_role r
                 inner join sys_user_role ur on ur.role_id = r.id
        where ur.user_id = #{userId}
        order by r.id asc
    </select>
</mapper>
