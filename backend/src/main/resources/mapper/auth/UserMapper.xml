<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.roboadvisor.auth.mapper.UserMapper">

    <resultMap id="SysUserResultMap" type="com.finance.roboadvisor.auth.entity.SysUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectById" resultMap="SysUserResultMap">
        select id, username, password_hash, nickname, phone, email, status, created_at, updated_at
        from sys_user
        where id = #{id}
    </select>

    <select id="selectByUsername" resultMap="SysUserResultMap">
        select id, username, password_hash, nickname, phone, email, status, created_at, updated_at
        from sys_user
        where username = #{username}
    </select>

    <select id="countByUsername" resultType="int">
        select count(1)
        from sys_user
        where username = #{username}
    </select>

    <select id="countByPhone" resultType="int">
        select count(1)
        from sys_user
        where phone = #{phone}
    </select>

    <insert id="insert" parameterType="com.finance.roboadvisor.auth.entity.SysUser" useGeneratedKeys="true" keyProperty="id">
        insert into sys_user (username, password_hash, nickname, phone, status)
        values (#{username}, #{passwordHash}, #{nickname}, #{phone}, #{status})
    </insert>
</mapper>
