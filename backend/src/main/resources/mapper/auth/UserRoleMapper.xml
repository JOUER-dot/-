<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.roboadvisor.auth.mapper.UserRoleMapper">

    <insert id="insert" parameterType="com.finance.roboadvisor.auth.entity.SysUserRole" useGeneratedKeys="true" keyProperty="id">
        insert into sys_user_role (user_id, role_id)
        values (#{userId}, #{roleId})
    </insert>
</mapper>
