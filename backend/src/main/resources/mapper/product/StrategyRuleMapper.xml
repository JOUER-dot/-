<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.finance.roboadvisor.product.mapper.StrategyRuleMapper">

    <resultMap id="StrategyRuleResultMap" type="com.finance.roboadvisor.product.entity.AdvisorStrategyRule">
        <id property="id" column="id"/>
        <result property="strategyCode" column="strategy_code"/>
        <result property="productType" column="product_type"/>
        <result property="minFundCount" column="min_fund_count"/>
        <result property="maxFundCount" column="max_fund_count"/>
        <result property="minSingleWeight" column="min_single_weight"/>
        <result property="maxSingleWeight" column="max_single_weight"/>
        <result property="allowFundTypes" column="allow_fund_types"/>
        <result property="riskRuleMode" column="risk_rule_mode"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">
        id, strategy_code, product_type, min_fund_count, max_fund_count, min_single_weight, max_single_weight,
        allow_fund_types, risk_rule_mode, status, created_at, updated_at
    </sql>

    <select id="selectEnabledByStrategyAndType" resultMap="StrategyRuleResultMap">
        select <include refid="BaseColumns"/>
        from advisor_strategy_rule
        where strategy_code = #{strategyCode}
          and product_type = #{productType}
          and status = 1
        limit 1
    </select>

    <select id="selectAllEnabled" resultMap="StrategyRuleResultMap">
        select <include refid="BaseColumns"/>
        from advisor_strategy_rule
        where status = 1
        order by strategy_code asc
    </select>
</mapper>
